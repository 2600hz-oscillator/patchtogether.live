# Dependencies
node_modules/

# Build output
packages/dsp/dist/
packages/web/.svelte-kit/
packages/web/build/
packages/server/dist/
docs/dist/
docs/.astro/
docs/src/data/modules.json
**/.vite/

# Environment
.env
.env.local
.env.*.local

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
*~

# Test artifacts
art/__diffs__/
vrt/test-results/
vrt/playwright-report/
e2e/test-results/
e2e/playwright-report/
coverage/

# Logs
npm-debug.log*
*.log

# Flox keeps its run state local
.flox/run/
.flox/cache/

# Wrangler / Cloudflare local state
.wrangler/
**/.wrangler/

# Local Claude Code settings (per-machine, don't commit)
.claude/*
!.claude/skills/
!.claude/skills/**

# Local agent / planning notes (treated like a scratchpad — never commit)
.myrobots/

# Playwright artifacts that aren't already covered above
e2e/.last-run.json
**/playwright-report/
**/test-results/

# VRT gallery output — generated by `task vrt:gallery` from
# e2e/vrt/__screenshots__/** + the last test-results/. CI regenerates this
# and uploads to GitHub Pages; never commit it to main.
docs/vrt/
e2e/vrt/report/

# Synthesised test-time artifacts (gitignored on PR #224 too)
e2e/.generated/
