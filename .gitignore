# Dependencies
node_modules/

# Build output
packages/dsp/dist/
packages/web/.svelte-kit/
packages/web/build/
packages/server/dist/
docs/dist/
docs/.astro/
docs/src/data/modules.json
**/.vite/

# Environment
.env
.env.local
.env.*.local

# Infra / observability secrets handed in locally (NEVER commit). The Better
# Stack read/write API key lives here; the secret inventory + admin runbooks
# are in the private ../patchtogether-infra-docs repo, not this public repo.
betterstack.txt
*.token
*.secret

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
*~

# Test artifacts
art/__diffs__/
vrt/test-results/
vrt/playwright-report/
e2e/test-results/
e2e/playwright-report/
e2e/vrt/test-results-annotated/
coverage/

# Synthesised test-time artifacts. The registry manifest is emitted by
# packages/web/src/lib/dev/registry-manifest.test.ts on every `task test`
# run and consumed by every Playwright spec that iterates the module
# registry — keep it out of git so PR diffs don't bounce on it.
e2e/.generated/

# Logs
npm-debug.log*
*.log

# Flox keeps its run state local
.flox/run/
.flox/cache/

# Wrangler / Cloudflare local state
.wrangler/
**/.wrangler/

# Local Claude Code settings (per-machine, don't commit)
.claude/*
!.claude/skills/
!.claude/skills/**

# Local agent / planning notes (treated like a scratchpad — never commit)
.myrobots/

# Playwright artifacts that aren't already covered above
e2e/.last-run.json
**/playwright-report/
**/test-results/

# VRT gallery output — generated by `task vrt:gallery` from
# e2e/vrt/__screenshots__/** + the last test-results/. CI regenerates this
# and uploads to GitHub Pages; never commit it to main.
docs/vrt/
e2e/vrt/report/

# Per-PR VRT changeset gallery (only-the-changed baselines, OLD/NEW/DIFF) —
# generated by scripts/vrt-changeset-gallery.mjs and published per-PR to CF
# Pages by .github/workflows/vrt-changeset-gallery.yml. Never committed.
docs/vrt-changeset/

# Test Reconciliation page output — index.html is regenerated at deploy time
# by scripts/build-test-reconciliation-page.mjs (current counts kept honest in
# CI). The committed history (changelog.json + CHANGELOG.md) IS tracked; only
# the generated HTML is ignored.
docs/test-reconciliation/index.html

# Synthesised test-time artifacts (gitignored on PR #224 too)
e2e/.generated/

# Long-lived local single-test server state (PID + logs) created by
# `task e2e:serve` / scripts/dev-server.sh. Per-machine runtime; never commit.
.dev-server/

# QBERT arcade ROM (user-provided; never commit binary ROM data). Follows
# the DOOM .WAD pattern — contributors drop their own qbert.zip via
# `task setup:qbert`; the static dir is empty in git. README in
# packages/web/static/roms/qbert/ documents the source + setup flow.
packages/web/static/roms/qbert/*
!packages/web/static/roms/qbert/README.md

# SNES9X SNES ROM (user-provided; never commit binary ROM data). Follows
# the DOOM .WAD / QBERT pattern — contributors supply their own
# .sfc/.smc via `task setup:snes9x` (it lands as game.sfc); the static dir
# carries only README.md in git. README in packages/web/static/roms/snes9x/
# documents the source + setup flow.
packages/web/static/roms/snes9x/*
!packages/web/static/roms/snes9x/README.md
