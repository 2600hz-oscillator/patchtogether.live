{
  "name": "@patchtogether.live/e2e",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "End-to-end tests for patchtogether.live via Playwright. Doubles as an AI-agent self-validation harness — see scripts ai:check + ai:debug.",
  "scripts": {
    "test": "playwright test",
    "ai:check": "playwright test --reporter=list ai-smoke.spec.ts",
    "ai:debug": "playwright test --reporter=list ai-debug.spec.ts",
    "vrt": "playwright test --config=vrt/vrt.config.ts",
    "vrt:strict": "VRT_STRICT=1 playwright test --config=vrt/vrt.config.ts",
    "vrt:update": "playwright test --config=vrt/vrt.config.ts --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0"
  }
}
