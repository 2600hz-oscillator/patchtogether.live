# Audio Regression Test baselines (D16 + testing-strategy.md)
art/baselines/**/*.f32 filter=lfs diff=lfs merge=lfs -text
art/baselines/**/*.wav filter=lfs diff=lfs merge=lfs -text

# Visual Regression Test baselines (Playwright `toHaveScreenshot`,
# config at e2e/vrt/vrt.config.ts, baselines under e2e/vrt/__screenshots__/).
# Scoped path on purpose so other PNGs in the repo (icons, docs assets)
# are stored as ordinary blobs — only the VRT card baselines are LFS-tracked.
# CI must `actions/checkout@v4` with `lfs: true` for the VRT job to compare
# against real bytes instead of LFS pointer files.
e2e/vrt/__screenshots__/**/*.png filter=lfs diff=lfs merge=lfs -text

# Numbered-control DEVICE-FACE doc assets (docs-overhaul §4a). Generated by
# `task vrt:annotated` (vrt-annotated.spec.ts), committed so the prerendered
# doc page always has the asset. Same LFS rationale as the VRT card baselines:
# regenerated on every card-control change → would balloon pack history.
# (The {type}.legend.json siblings are tiny in-repo JSON — NOT LFS — so the
# doc loader can glob-import them at Vite build time.)
e2e/vrt/__annotated__/**/*.png filter=lfs diff=lfs merge=lfs -text

# Bundled wavetables for Wavetable VCO
packages/dsp/wavetables/*.wav filter=lfs diff=lfs merge=lfs -text

# Built WASM is gitignored, but if any pre-built WASM ever gets checked in:
**/*.wasm filter=lfs diff=lfs merge=lfs -text

# Bundled 1997 Blood SHAREWARE game data (un-ignored in .gitignore so the BLOOD
# card boots out-of-box on the beta-gated deploys). These are large binary
# resource files (BLOOD.RFF ~3.2 MB, SOUNDS.RFF ~15 MB, SHARE000.ART ~16 MB), so
# LFS-track them like the VRT/ART baselines — keeps them out of pack history.
# Scoped to static/blood so other repo .DAT/.ART (if any) stay ordinary blobs.
packages/web/static/blood/*.RFF filter=lfs diff=lfs merge=lfs -text
packages/web/static/blood/*.ART filter=lfs diff=lfs merge=lfs -text
packages/web/static/blood/*.DAT filter=lfs diff=lfs merge=lfs -text
