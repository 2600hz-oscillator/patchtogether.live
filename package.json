{
  "name": "patchtogether.live",
  "version": "1.2.0",
  "private": true,
  "description": "A multiplayer browser-native modular synthesizer.",
  "license": "AGPL-3.0-or-later",
  "workspaces": [
    "packages/dsp",
    "packages/server",
    "packages/web",
    "art",
    "e2e"
  ],
  "overrides": {
    "yjs": "^13.6.0"
  },
  "scripts": {
    "dev": "npm run dev -w packages/web",
    "build": "npm run build -w packages/dsp && npm run build -w packages/web",
    "watch:dsp": "npm run watch -w packages/dsp",
    "test": "npm test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "pixelmatch": "^6.0.0"
  }
}
