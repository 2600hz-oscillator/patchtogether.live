{
  "name": "@inet.modular/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "SvelteKit app for inet.modular — patch canvas + audio engine + UI.",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
