{
  "name": "@patchtogether.live/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "SvelteKit app for patchtogether.live — patch canvas + audio engine + UI.",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || true",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --threshold error",
    "test": "vitest run --config vitest.config.ts",
    "manifest": "node scripts/build-module-manifest.mjs"
  },
  "dependencies": {
    "@grame/faustwasm": "^0.7.0",
    "@hocuspocus/provider": "^4.0.0",
    "@neondatabase/serverless": "^1.1.0",
    "@syncedstore/core": "^0.6.0",
    "@xyflow/svelte": "^1.0.0",
    "svelte-clerk": "^1.1.6",
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.25",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "terser": "^5.46.2",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
