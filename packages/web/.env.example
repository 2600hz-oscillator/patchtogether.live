# Local development env. Copy to `.env.local` and fill in values.
# `.env.local` is gitignored. Production values live in Cloudflare Pages
# Variables and Secrets per project (see deploy.yml + the docs in
# wrangler.toml).

# Clerk auth (test instance shown — see Cloudflare for prod values).
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Hocuspocus collaboration server URL. Defaults to ws://localhost:1235 in
# code if unset (1235, not Hocuspocus's documented 1234, because BitwigStudio
# and other DAWs reserve 1234 for OSC). Local dev: leave blank or set to
# ws://localhost:1235 and run `task server:dev` in another terminal. Prod:
# ws(s) URL of the deployed @inet.modular/server (Fly.io once Stage B PR C lands).
VITE_SERVER_WS_URL=ws://localhost:1235

# Invite-code HMAC secret. Used to derive `?invite=<code>` query params that
# allow anonymous viewing of /r/[id]. Must be set (>= 32 chars) in production;
# falls back to a deterministic dev string locally so the route works without
# extra env wiring. Rotating invalidates every outstanding invite.
#
# IMPORTANT: the @inet.modular/server package (Hocuspocus) ALSO reads
# INVITE_SECRET to verify `anon:<code>` tokens at the WS handshake (PR-D).
# Set the SAME value in the server's deploy env, or anon visitors will be
# rejected at connect time even with a valid invite URL.
INVITE_SECRET=replace-with-a-32-plus-char-random-string-for-prod

# Clerk session-key secret. Already set above for the SvelteKit web; the
# Hocuspocus server (@patchtogether.live/server) ALSO needs CLERK_SECRET_KEY in
# its deploy env to verify `clerk:<jwt>` handshake tokens (PR-D). Same
# value as web's CLERK_SECRET_KEY.

# Beta-gate basic-auth password. While the site is in beta, hooks.server.ts
# enforces a basic-auth prompt on every route (except /api/health). Unset
# locally to disable the gate. Username is fixed (`beta` by default; override
# via BETA_GATE_USER if you need to). Different value per env in production:
# dev=`2600hz`, autotest+prod=`robotsonly`.
# BETA_GATE_USER=beta
# BETA_GATE_PASS=...
