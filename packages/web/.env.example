# Local development env. Copy to `.env.local` and fill in values.
# `.env.local` is gitignored. Production values live in Cloudflare Pages
# Variables and Secrets per project (see deploy.yml + the docs in
# wrangler.toml).

# Clerk auth (test instance shown — see Cloudflare for prod values).
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Hocuspocus collaboration server URL. Defaults to ws://localhost:1235 in
# code if unset (1235, not Hocuspocus's documented 1234, because BitwigStudio
# and other DAWs reserve 1234 for OSC). Local dev: leave blank or set to
# ws://localhost:1235 and run `task server:dev` in another terminal. Prod:
# ws(s) URL of the deployed @inet.modular/server (Fly.io once Stage B PR C lands).
VITE_SERVER_WS_URL=ws://localhost:1235
