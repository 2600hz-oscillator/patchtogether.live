{
  "version": 1,
  "note": "TOYBOX Phase 1 content bank. Each entry declares its float-uniform params — the single source of truth for the card faders (and later CV targets). GLSL is fetched lazily from `glsl` on selection (NOT JS-bundled). GEN families live under `gen`, FX families under `shaders`.",
  "shaders": [
    {
      "id": "frag-invert-scan",
      "label": "FRAG INVERT-SCAN",
      "family": "FRAG",
      "glsl": "/toybox/shaders/frag-invert-scan.frag.glsl",
      "shadertoy": true,
      "input": "scene",
      "params": [
        { "id": "amount", "label": "AMOUNT", "min": 0.0, "max": 1.0,  "default": 1.0, "curve": "linear" },
        { "id": "split",  "label": "SPLIT",  "min": 0.0, "max": 12.0, "default": 3.0, "curve": "linear" }
      ]
    },
    {
      "id": "hsv-plasma",
      "label": "HSV PLASMA",
      "family": "FX",
      "glsl": "/toybox/shaders/hsv-plasma.frag.glsl",
      "params": [
        { "id": "speed", "label": "SPEED", "min": 0.0, "max": 3.0, "default": 1.0, "curve": "linear" },
        { "id": "hue",   "label": "HUE",   "min": 0.0, "max": 1.0, "default": 0.0, "curve": "linear" },
        { "id": "sat",   "label": "SAT",   "min": 0.0, "max": 1.0, "default": 1.0, "curve": "linear" }
      ]
    },
    {
      "id": "cos-gradient",
      "label": "COS GRADIENT",
      "family": "FX",
      "glsl": "/toybox/shaders/cos-gradient.frag.glsl",
      "params": [
        { "id": "speed", "label": "SPEED", "min": 0.0, "max": 3.0, "default": 0.5, "curve": "linear" },
        { "id": "phase", "label": "PHASE", "min": 0.0, "max": 1.0, "default": 0.0, "curve": "linear" },
        { "id": "scale", "label": "SCALE", "min": 0.5, "max": 8.0, "default": 3.0, "curve": "linear" }
      ]
    },
    {
      "id": "frag-iq-palette-map",
      "label": "FRAG IQ-PALETTE",
      "family": "FRAG",
      "glsl": "/toybox/shaders/frag-iq-palette-map.frag.glsl",
      "shadertoy": true,
      "input": "scene",
      "params": [
        { "id": "amount", "label": "AMOUNT", "min": 0.0, "max": 1.0, "default": 1.0, "curve": "linear" },
        { "id": "shift",  "label": "SHIFT",  "min": 0.0, "max": 1.0, "default": 0.0, "curve": "linear" },
        { "id": "spread", "label": "SPREAD", "min": 0.1, "max": 4.0, "default": 1.0, "curve": "linear" }
      ]
    },
    {
      "id": "frag-kaleido",
      "label": "FRAG KALEIDO",
      "family": "FRAG",
      "glsl": "/toybox/shaders/frag-kaleido.frag.glsl",
      "shadertoy": true,
      "input": "scene",
      "params": [
        { "id": "segments", "label": "SEGMENTS", "min": 2.0, "max": 16.0, "default": 6.0, "curve": "discrete" },
        { "id": "spin",     "label": "SPIN",     "min": -2.0, "max": 2.0, "default": 0.4, "curve": "linear" },
        { "id": "zoom",     "label": "ZOOM",     "min": 0.2, "max": 3.0,  "default": 1.0, "curve": "linear" }
      ]
    },
    {
      "id": "frag-metaballs-overlay",
      "label": "FRAG METABALLS",
      "family": "FRAG",
      "glsl": "/toybox/shaders/frag-metaballs-overlay.frag.glsl",
      "shadertoy": true,
      "input": "scene",
      "params": [
        { "id": "count",   "label": "COUNT",   "min": 1.0, "max": 6.0, "default": 4.0, "curve": "discrete" },
        { "id": "radius",  "label": "RADIUS",  "min": 0.05, "max": 0.6, "default": 0.28, "curve": "linear" },
        { "id": "refract", "label": "REFRACT", "min": 0.0, "max": 1.0, "default": 0.6, "curve": "linear" }
      ]
    },
    {
      "id": "frag-sdf-tunnel",
      "label": "FRAG SDF-TUNNEL",
      "family": "FRAG",
      "glsl": "/toybox/shaders/frag-sdf-tunnel.frag.glsl",
      "shadertoy": true,
      "input": "scene",
      "params": [
        { "id": "speed", "label": "SPEED", "min": 0.0, "max": 3.0, "default": 0.6, "curve": "linear" },
        { "id": "twist", "label": "TWIST", "min": 0.0, "max": 3.0, "default": 0.8, "curve": "linear" },
        { "id": "fog",   "label": "FOG",   "min": 0.0, "max": 1.0, "default": 0.7, "curve": "linear" }
      ]
    },
    {
      "id": "frag-moire",
      "label": "FRAG MOIRE",
      "family": "FRAG",
      "glsl": "/toybox/shaders/frag-moire.frag.glsl",
      "shadertoy": true,
      "input": "scene",
      "params": [
        { "id": "freq",     "label": "FREQ",     "min": 2.0, "max": 24.0, "default": 8.0, "curve": "linear" },
        { "id": "beat",     "label": "BEAT",     "min": 0.0, "max": 0.5,  "default": 0.1, "curve": "linear" },
        { "id": "displace", "label": "DISPLACE", "min": 0.0, "max": 2.0,  "default": 0.6, "curve": "linear" }
      ]
    },
    {
      "id": "frag-vhs-bars",
      "label": "FRAG VHS-BARS",
      "family": "FRAG",
      "glsl": "/toybox/shaders/frag-vhs-bars.frag.glsl",
      "shadertoy": true,
      "input": "scene",
      "params": [
        { "id": "jitter", "label": "JITTER", "min": 0.0, "max": 2.0, "default": 0.7, "curve": "linear" },
        { "id": "bleed",  "label": "BLEED",  "min": 0.0, "max": 8.0, "default": 2.0, "curve": "linear" },
        { "id": "bar",    "label": "BAR",    "min": 0.0, "max": 1.0, "default": 0.7, "curve": "linear" }
      ]
    }
  ],
  "gen": [
    {
      "id": "synthwave-sunset",
      "label": "SYNTHWAVE SUNSET",
      "family": "GEN",
      "glsl": "/toybox/shaders/synthwave-sunset.frag.glsl",
      "shadertoy": true,
      "input": "none",
      "params": []
    },
    {
      "id": "noise-fbm",
      "label": "NOISE FBM",
      "family": "GEN",
      "glsl": "/toybox/shaders/noise-fbm.frag.glsl",
      "params": [
        { "id": "scale", "label": "SCALE", "min": 0.5, "max": 6.0, "default": 2.0, "curve": "linear" },
        { "id": "speed", "label": "SPEED", "min": 0.0, "max": 2.0, "default": 0.4, "curve": "linear" },
        { "id": "warp",  "label": "WARP",  "min": 0.0, "max": 2.0, "default": 0.8, "curve": "linear" }
      ]
    },
    {
      "id": "worley-cells",
      "label": "WORLEY CELLS",
      "family": "GEN",
      "glsl": "/toybox/shaders/worley-cells.frag.glsl",
      "params": [
        { "id": "density", "label": "DENSITY", "min": 1.0, "max": 16.0, "default": 6.0, "curve": "linear" },
        { "id": "edge",    "label": "EDGE",    "min": 0.0, "max": 2.0,  "default": 1.0, "curve": "linear" },
        { "id": "speed",   "label": "SPEED",   "min": 0.0, "max": 3.0,  "default": 0.6, "curve": "linear" }
      ]
    },
    {
      "id": "voronoi-edges",
      "label": "VORONOI EDGES",
      "family": "GEN",
      "glsl": "/toybox/shaders/voronoi-edges.frag.glsl",
      "params": [
        { "id": "density", "label": "DENSITY", "min": 1.0, "max": 16.0, "default": 5.0, "curve": "linear" },
        { "id": "edge",    "label": "EDGE",    "min": 0.0, "max": 2.0,  "default": 1.0, "curve": "linear" },
        { "id": "speed",   "label": "SPEED",   "min": 0.0, "max": 3.0,  "default": 0.5, "curve": "linear" }
      ]
    },
    {
      "id": "gradient-noise",
      "label": "GRADIENT NOISE",
      "family": "GEN",
      "glsl": "/toybox/shaders/gradient-noise.frag.glsl",
      "params": [
        { "id": "scale", "label": "SCALE", "min": 0.5, "max": 6.0, "default": 2.0, "curve": "linear" },
        { "id": "speed", "label": "SPEED", "min": 0.0, "max": 2.0, "default": 0.4, "curve": "linear" },
        { "id": "gain",  "label": "GAIN",  "min": 0.3, "max": 0.75, "default": 0.5, "curve": "linear" }
      ]
    },
    {
      "id": "hex-grid",
      "label": "HEX GRID",
      "family": "GEN",
      "glsl": "/toybox/shaders/hex-grid.frag.glsl",
      "params": [
        { "id": "scale", "label": "SCALE", "min": 1.0, "max": 24.0, "default": 8.0, "curve": "linear" },
        { "id": "pulse", "label": "PULSE", "min": 0.0, "max": 1.0,  "default": 0.5, "curve": "linear" },
        { "id": "edge",  "label": "EDGE",  "min": 0.25, "max": 3.0, "default": 1.0, "curve": "linear" }
      ]
    },
    {
      "id": "truchet",
      "label": "TRUCHET",
      "family": "GEN",
      "glsl": "/toybox/shaders/truchet.frag.glsl",
      "params": [
        { "id": "scale", "label": "SCALE", "min": 1.0, "max": 16.0, "default": 6.0, "curve": "linear" },
        { "id": "width", "label": "WIDTH", "min": 0.2, "max": 3.0,  "default": 1.0, "curve": "linear" },
        { "id": "flow",  "label": "FLOW",  "min": 0.0, "max": 2.0,  "default": 0.6, "curve": "linear" }
      ]
    },
    {
      "id": "star-field",
      "label": "STAR FIELD",
      "family": "GEN",
      "glsl": "/toybox/shaders/star-field.frag.glsl",
      "params": [
        { "id": "density", "label": "DENSITY", "min": 2.0, "max": 24.0, "default": 10.0, "curve": "linear" },
        { "id": "speed",   "label": "SPEED",   "min": 0.0, "max": 3.0,  "default": 1.0,  "curve": "linear" },
        { "id": "warp",    "label": "WARP",    "min": 0.0, "max": 2.0,  "default": 0.8,  "curve": "linear" }
      ]
    },
    {
      "id": "reaction-diffusion-still",
      "label": "REACTION DIFFUSION",
      "family": "GEN",
      "glsl": "/toybox/shaders/reaction-diffusion-still.frag.glsl",
      "params": [
        { "id": "scale",    "label": "SCALE",    "min": 0.5, "max": 4.0, "default": 1.5, "curve": "linear" },
        { "id": "contrast", "label": "CONTRAST", "min": 0.0, "max": 1.0, "default": 0.5, "curve": "linear" },
        { "id": "drift",    "label": "DRIFT",    "min": 0.0, "max": 1.0, "default": 0.4, "curve": "linear" }
      ]
    }
  ],
  "models": [
    { "id": "spot",       "label": "SPOT THE COW", "obj": "/toybox/models/spot.obj",       "matcap": 1, "license": "CC0-1.0" },
    { "id": "teapot",     "label": "UTAH TEAPOT",  "obj": "/toybox/models/teapot.obj",     "matcap": 0, "license": "CC0-1.0" },
    { "id": "chess-pawn", "label": "CHESS PAWN",   "obj": "/toybox/models/chess-pawn.obj", "matcap": 2, "license": "CC0-1.0" },
    { "id": "cube",       "label": "CUBE",         "builtin": "cube",      "matcap": 0, "license": "builtin" },
    { "id": "sphere",     "label": "SPHERE",       "builtin": "sphere",    "matcap": 0, "license": "builtin" },
    { "id": "torus",      "label": "TORUS",        "builtin": "torus",     "matcap": 1, "license": "builtin" },
    { "id": "hypercube",  "label": "HYPERCUBE",    "builtin": "hypercube", "matcap": 2, "license": "builtin" },
    { "id": "tetrahedron", "label": "TETRAHEDRON", "builtin": "tetrahedron", "matcap": 0, "license": "builtin" },
    { "id": "octahedron",  "label": "OCTAHEDRON",  "builtin": "octahedron",  "matcap": 1, "license": "builtin" },
    { "id": "icosahedron", "label": "ICOSAHEDRON", "builtin": "icosahedron", "matcap": 2, "license": "builtin" },
    { "id": "cylinder",    "label": "CYLINDER",    "builtin": "cylinder",    "matcap": 0, "license": "builtin" },
    { "id": "cone",        "label": "CONE",        "builtin": "cone",        "matcap": 1, "license": "builtin" },
    { "id": "torus-knot",  "label": "TORUS KNOT",  "builtin": "torus-knot",  "matcap": 2, "license": "builtin" },
    { "id": "banana",      "label": "BANANA",      "obj": "/toybox/models/banana.obj",  "matcap": 1, "license": "CC0-1.0" },
    { "id": "snowman",     "label": "SNOWMAN",     "obj": "/toybox/models/snowman.obj", "matcap": 0, "license": "CC0-1.0" }
  ],
  "presets": [
    {
      "id": "plasma-dissolve",
      "label": "PLASMA DISSOLVE",
      "note": "Shader-only crossfade: hsv-plasma faded over cos-gradient. cv1 drives the fade.",
      "layers": [
        { "kind": "shader", "contentId": "hsv-plasma",   "params": { "speed": 1.0, "hue": 0.2, "sat": 1.0 } },
        { "kind": "shader", "contentId": "cos-gradient",  "params": { "speed": 0.5, "phase": 0.0, "scale": 3.0 } },
        { "kind": "off", "contentId": null, "params": {} },
        { "kind": "off", "contentId": null, "params": {} }
      ],
      "combine": {
        "nodes": [
          { "id": "src0", "kind": "source", "layer": 0, "x": 14, "y": 14 },
          { "id": "src1", "kind": "source", "layer": 1, "x": 14, "y": 66 },
          { "id": "src2", "kind": "source", "layer": 2, "x": 14, "y": 118 },
          { "id": "src3", "kind": "source", "layer": 3, "x": 14, "y": 170 },
          { "id": "fade1", "kind": "fade", "x": 120, "y": 40, "params": { "amount": 0.5 } },
          { "id": "out", "kind": "output", "x": 286, "y": 40 }
        ],
        "edges": [
          { "id": "e0", "from": "src0", "to": "fade1", "toPort": "in0" },
          { "id": "e1", "from": "src1", "to": "fade1", "toPort": "in1" },
          { "id": "e2", "from": "fade1", "to": "out", "toPort": "in0" }
        ]
      },
      "cvRoutes": {
        "cv1": { "target": "combine", "nodeId": "fade1", "param": "amount" }
      }
    },
    {
      "id": "cow-on-camera",
      "label": "COW ON CAMERA",
      "note": "OBJ luma-keyed over a generated backdrop: the chrome Spot floats over a worley field. cv3 spins the cow. (Layer 0 substitutes bundled worley-cells for a live video feed — TOYBOX has no video input port.)",
      "layers": [
        { "kind": "gen", "contentId": "worley-cells", "params": { "density": 6.0, "edge": 1.0, "speed": 0.6 } },
        {
          "kind": "obj", "contentId": null, "params": {},
          "material": {
            "modelId": "spot", "rotX": 0.3, "rotY": 0.6, "rotZ": 0.0,
            "scale": 1.0, "spin": 0.6, "matcap": 0, "tintR": 1.0, "tintG": 1.0, "tintB": 1.0
          }
        },
        { "kind": "off", "contentId": null, "params": {} },
        { "kind": "off", "contentId": null, "params": {} }
      ],
      "combine": {
        "nodes": [
          { "id": "src0", "kind": "source", "layer": 0, "x": 14, "y": 14 },
          { "id": "src1", "kind": "source", "layer": 1, "x": 14, "y": 66 },
          { "id": "src2", "kind": "source", "layer": 2, "x": 14, "y": 118 },
          { "id": "src3", "kind": "source", "layer": 3, "x": 14, "y": 170 },
          { "id": "lk1", "kind": "lumakey", "x": 120, "y": 40, "params": { "amount": 0.05, "soft": 0.1, "invert": 0 } },
          { "id": "out", "kind": "output", "x": 286, "y": 40 }
        ],
        "edges": [
          { "id": "e0", "from": "src0", "to": "lk1", "toPort": "in0" },
          { "id": "e1", "from": "src1", "to": "lk1", "toPort": "in1" },
          { "id": "e2", "from": "lk1", "to": "out", "toPort": "in0" }
        ]
      },
      "cvRoutes": {
        "cv3": { "target": "layer", "layer": 1, "param": "material:spin" }
      }
    },
    {
      "id": "worley-bloom",
      "label": "WORLEY BLOOM",
      "note": "Three-source chain: worley chroma-keyed over a gradient, screen-mapped with plasma. cv2 drives the map mix, cv5 the worley density. (Layer 1 substitutes bundled cos-gradient for a live video feed.)",
      "layers": [
        { "kind": "gen", "contentId": "worley-cells", "params": { "density": 8.0, "edge": 1.2, "speed": 0.5 } },
        { "kind": "gen", "contentId": "cos-gradient", "params": { "speed": 0.4, "phase": 0.3, "scale": 4.0 } },
        { "kind": "shader", "contentId": "hsv-plasma", "params": { "speed": 0.8, "hue": 0.6, "sat": 1.0 } },
        { "kind": "off", "contentId": null, "params": {} }
      ],
      "combine": {
        "nodes": [
          { "id": "src0", "kind": "source", "layer": 0, "x": 14, "y": 14 },
          { "id": "src1", "kind": "source", "layer": 1, "x": 14, "y": 66 },
          { "id": "src2", "kind": "source", "layer": 2, "x": 14, "y": 118 },
          { "id": "src3", "kind": "source", "layer": 3, "x": 14, "y": 170 },
          { "id": "ck1", "kind": "chromakey", "x": 120, "y": 14, "params": { "amount": 0.3, "soft": 0.1, "key": 0.33 } },
          { "id": "map1", "kind": "map", "x": 120, "y": 118, "params": { "amount": 0.7, "mode": 1 } },
          { "id": "out", "kind": "output", "x": 286, "y": 66 }
        ],
        "edges": [
          { "id": "e0", "from": "src0", "to": "ck1", "toPort": "in0" },
          { "id": "e1", "from": "src1", "to": "ck1", "toPort": "in1" },
          { "id": "e2", "from": "ck1", "to": "map1", "toPort": "in0" },
          { "id": "e3", "from": "src2", "to": "map1", "toPort": "in1" },
          { "id": "e4", "from": "map1", "to": "out", "toPort": "in0" }
        ]
      },
      "cvRoutes": {
        "cv2": { "target": "combine", "nodeId": "map1", "param": "amount" },
        "cv5": { "target": "layer", "layer": 0, "param": "density" }
      }
    },
    {
      "id": "textured-sphere",
      "label": "TEXTURED SPHERE",
      "note": "Texmap showcase: layer 0 = a sphere whose SURFACE is layer 1's worley field (material.surfaceSource = 1), UV-mapped onto the mesh instead of a flat matcap. Layer 1 renders the worley shader (also the OUTPUT base so the field shows around the textured sphere).",
      "layers": [
        {
          "kind": "obj", "contentId": null, "params": {},
          "material": {
            "modelId": "sphere", "rotX": 0.3, "rotY": 0.6, "rotZ": 0.0,
            "scale": 1.0, "spin": 0.0, "matcap": 0, "tintR": 1.0, "tintG": 1.0, "tintB": 1.0,
            "surfaceSource": 1, "surfaceMix": 1.0
          }
        },
        { "kind": "gen", "contentId": "worley-cells", "params": { "density": 6.0, "edge": 1.0, "speed": 0.6 } },
        { "kind": "off", "contentId": null, "params": {} },
        { "kind": "off", "contentId": null, "params": {} }
      ],
      "combine": {
        "nodes": [
          { "id": "src0", "kind": "source", "layer": 0, "x": 14, "y": 14 },
          { "id": "src1", "kind": "source", "layer": 1, "x": 14, "y": 66 },
          { "id": "src2", "kind": "source", "layer": 2, "x": 14, "y": 118 },
          { "id": "src3", "kind": "source", "layer": 3, "x": 14, "y": 170 },
          { "id": "fade1", "kind": "fade", "x": 120, "y": 40, "params": { "amount": 1.0 } },
          { "id": "out", "kind": "output", "x": 286, "y": 40 }
        ],
        "edges": [
          { "id": "e0", "from": "src1", "to": "fade1", "toPort": "in0" },
          { "id": "e1", "from": "src0", "to": "fade1", "toPort": "in1" },
          { "id": "e2", "from": "fade1", "to": "out", "toPort": "in0" }
        ]
      },
      "cvRoutes": {}
    },
    {
      "id": "reactor-field",
      "label": "REACTOR FIELD",
      "note": "Multi-stage gen + obj + shader: noise screen-mapped with worley, then a neon teapot luma-keyed over the field.",
      "layers": [
        { "kind": "gen", "contentId": "noise-fbm",    "params": { "scale": 2.0, "speed": 0.4, "warp": 0.8 } },
        { "kind": "gen", "contentId": "worley-cells",  "params": { "density": 6.0, "edge": 1.0, "speed": 0.6 } },
        {
          "kind": "obj", "contentId": null, "params": {},
          "material": {
            "modelId": "teapot", "rotX": 0.5, "rotY": 0.7, "rotZ": 0.0,
            "scale": 1.0, "spin": 0.4, "matcap": 2, "tintR": 1.0, "tintG": 1.0, "tintB": 1.0
          }
        },
        { "kind": "off", "contentId": null, "params": {} }
      ],
      "combine": {
        "nodes": [
          { "id": "src0", "kind": "source", "layer": 0, "x": 14, "y": 14 },
          { "id": "src1", "kind": "source", "layer": 1, "x": 14, "y": 66 },
          { "id": "src2", "kind": "source", "layer": 2, "x": 14, "y": 118 },
          { "id": "src3", "kind": "source", "layer": 3, "x": 14, "y": 170 },
          { "id": "map1", "kind": "map", "x": 120, "y": 14, "params": { "amount": 1.0, "mode": 1 } },
          { "id": "lk1", "kind": "lumakey", "x": 120, "y": 118, "params": { "amount": 0.05, "soft": 0.1, "invert": 0 } },
          { "id": "out", "kind": "output", "x": 286, "y": 66 }
