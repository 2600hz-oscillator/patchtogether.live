{
  "name": "@patchtogether.live/server",
  "version": "0.0.0",
  "private": true,
  "description": "Hocuspocus + (later) WebRTC signaling for patchtogether.live multi-user rackspaces. Stage B onward.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --reporter=default"
  },
  "dependencies": {
    "@clerk/backend": "^2.20.0",
    "@hocuspocus/server": "^2.13.5",
    "pg": "^8.20.0",
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "convert-source-map": "^2.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.0"
  }
}
